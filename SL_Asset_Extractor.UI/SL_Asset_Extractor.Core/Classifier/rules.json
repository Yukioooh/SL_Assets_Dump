{
  "rules": [
    {
      "category": "Characters",
      "keywords": [ "asung", "jinwoo", "chae", "baek", "goto", "thomas", "char_", "character_" ],
      "patterns": [ "^char_", "^character_" ]
    },
    {
      "category": "Bosses",
      "keywords": [ "baran", "antares", "bellion", "queenant" ],
      "patterns": [ "^boss_", "^dungeon_boss_" ]
    },
    {
      "category": "Skills",
      "keywords": [ "skill_", "ability_", "spell_" ],
      "patterns": [ "^sk_", "^ability_", "^skill_" ]
    },
    {
      "category": "Banners",
      "keywords": [ "banner_", "gacha_", "summon_", "recruitment_" ],
      "patterns": [ "^banner_", "^recruitment_" ]
    },
    {
      "category": "UI",
      "keywords": [ "ui_", "icon_", "button_", "frame_", "bg_", "hud_", "menu_" ],
      "patterns": [ "^ui_", "^hud_", "^menu_", "^icon_" ]
    },
    {
      "category": "Effects",
      "keywords": [ "vfx_", "fx_", "effect_", "particle_" ],
      "patterns": [ "^vfx_", "^fx_", "^effect_" ]
    },
    {
      "category": "Monsters",
      "keywords": [ "mob_", "monster_", "enemy_" ],
      "patterns": [ "^mob_", "^monster_", "^enemy_" ]
    },
    {
      "category": "Items",
      "keywords": [ "item_", "weapon_", "armor_", "gear_" ],
      "patterns": [ "^item_", "^weapon_", "^armor_" ]
    }
  ],
  "defaultCategory": "Unclassified"
}