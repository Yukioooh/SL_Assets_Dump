<Window x:Class="SL_Asset_Extractor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arise"
        Width="1200" Height="700"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="MS Sans Serif"
        FontSize="12"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Icon="Resources/Img_GachaDirection_GuildIcon_1.ico">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="MinWidth" Value="75"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barre de titre custom -->
        <Grid Grid.Row="0"
              Background="#4C0F96"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icone + Titre -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0">
                <Image Source="Resources/Img_GachaDirection_GuildIcon_1.ico"
                       Width="18"
                       Height="18"
                       Margin="0,0,6,0"/>
                <TextBlock Text="Arise"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="13"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Espace vide draggable -->
            <Rectangle Grid.Column="1" Fill="Transparent"/>

            <!-- Bouton Réduire -->
            <Button Grid.Column="2"
                    Content="─"
                    Width="46"
                    Height="32"
                    MinWidth="0"
                    Padding="0"
                    FontSize="14"
                    Click="MinimizeButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#5D20A7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Bouton Maximiser -->
            <Button Grid.Column="3"
                    Content="□"
                    Width="46"
                    Height="32"
                    MinWidth="0"
                    Padding="0"
                    FontSize="14"
                    Click="MaximizeButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#5D20A7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Bouton Fermer -->
            <Button Grid.Column="4"
                    Content="✕"
                    Width="46"
                    Height="32"
                    MinWidth="0"
                    Padding="0"
                    FontSize="13"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E81123"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Contenu principal -->
        <Grid Grid.Row="1" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="200" MinWidth="150"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="140" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Séparateur redimensionnable gauche -->
            <GridSplitter Grid.Column="0"
                          Grid.RowSpan="2"
                          Width="4"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Stretch"
                          Background="#CCCCCC"
                          Margin="0,0,-2,0"/>

            <!-- Séparateur redimensionnable droite -->
            <GridSplitter Grid.Column="2"
                          Grid.RowSpan="2"
                          Width="4"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Stretch"
                          Background="#CCCCCC"
                          Margin="-2,0,0,0"/>

            <!-- Séparateur horizontal bas -->
            <GridSplitter Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Grid.Row="1"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Background="#CCCCCC"
                          Margin="0,-2,0,0"/>

            <!-- Colonne gauche -->
            <ScrollViewer Grid.Column="0"
                          Grid.Row="0"
                          Grid.RowSpan="2"
                          Margin="0,0,6,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <GroupBox Header="Dossiers sources">
                        <StackPanel>
                            <ListBox ItemsSource="{Binding ScanVM.SourceFolders}"
                                     MaxHeight="150"
                                     Margin="0,0,0,4"
                                     FontSize="10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1"
                                                    Content="X"
                                                    Width="18" Height="18"
                                                    FontSize="9"
                                                    MinWidth="0"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding DataContext.ScanVM.RemoveSourceFolderCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Content="+ Ajouter un dossier"
                                    HorizontalAlignment="Stretch"
                                    Padding="8,6"
                                    Command="{Binding ScanVM.AddSourceFolderCommand}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Dossier d'export">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ScanVM.ExportFolder}"
                                     IsReadOnly="True"
                                     Padding="4,6"/>
                            <Button Grid.Column="1"
                                    Content="..."
                                    Width="32"
                                    MinWidth="0"
                                    Padding="0,6"
                                    Margin="2,0,0,0"
                                    Command="{Binding ScanVM.BrowseExportFolderCommand}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Options">
                        <StackPanel>
                            <CheckBox Content="Texture2D"
                                      IsChecked="{Binding ScanVM.ExtractTexture2D}"
                                      Margin="0,0,0,4"/>
                            <CheckBox Content="Sprite"
                                      IsChecked="{Binding ScanVM.ExtractSprite}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Actions">
                        <StackPanel>
                            <Button Content="Démarrer"
                                    Command="{Binding ScanVM.StartExtractionCommand}"
                                    HorizontalAlignment="Stretch"
                                    Padding="8,6"
                                    Margin="0,0,0,4"/>
                            <Button Content="Annuler"
                                    Command="{Binding ScanVM.CancelCommand}"
                                    HorizontalAlignment="Stretch"
                                    Padding="8,6"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Personnages">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <Button DockPanel.Dock="Right"
                                        Content="+"
                                        Width="22" Height="22"
                                        FontWeight="Bold"
                                        MinWidth="0"
                                        Padding="0"
                                        Command="{Binding ScanVM.AddCharacterCommand}"/>
                                <TextBlock Text="Liste des personnages"
                                           FontSize="10"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <ListBox ItemsSource="{Binding ScanVM.CharactersList}"
                                     MaxHeight="120"
                                     FontSize="10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1"
                                                    Content="X"
                                                    Width="16" Height="16"
                                                    FontSize="9"
                                                    MinWidth="0"
                                                    Padding="0"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding DataContext.ScanVM.RemoveCharacterCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Statut">
                        <StackPanel>
                            <TextBlock Text="{Binding ScanVM.StatusMessage}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"/>
                            <ProgressBar Value="{Binding ScanVM.Progress}"
                                         Maximum="{Binding ScanVM.ProgressMax}"
                                         Height="14"
                                         Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding ScanVM.ProgressText}"
                                       FontSize="10"
                                       Foreground="Gray"/>
                            <TextBlock Text="{Binding ScanVM.TimeRemaining}"
                                       FontSize="10"
                                       Foreground="Gray"/>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <!-- Zone centrale — Visionneuse -->
            <Grid Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Margin="4,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Filtres">
                    <WrapPanel>
                        <TextBlock Text="Catégorie :"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <ComboBox Width="120"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding BrowserVM.Categories}"
                                  SelectedItem="{Binding BrowserVM.SelectedCategory}"/>

                        <TextBlock Text="Sous-dossier :"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <ComboBox Width="120"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding BrowserVM.SubFolders}"
                                  SelectedItem="{Binding BrowserVM.SelectedSubFolder}"/>

                        <TextBlock Text="Détail :"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <ComboBox Width="100"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding BrowserVM.SubSubFolders}"
                                  SelectedItem="{Binding BrowserVM.SelectedSubSubFolder}"/>

                        <TextBlock Text="Recherche :"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBox Width="140"
                                 Margin="0,0,8,0"
                                 Padding="2,1"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding BrowserVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="Actualiser"
                                Margin="0,0,8,0"
                                Command="{Binding BrowserVM.RefreshCommand}"/>

                        <Button Content="◄"
                                MinWidth="0"
                                Width="30"
                                Margin="0,0,4,0"
                                Command="{Binding BrowserVM.PreviousPageCommand}"/>

                        <TextBlock Text="{Binding BrowserVM.PageInfo}"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   Margin="0,0,4,0"/>

                        <Button Content="►"
                                MinWidth="0"
                                Width="30"
                                Margin="0,0,8,0"
                                Command="{Binding BrowserVM.NextPageCommand}"/>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="Gray"
                                   Text="{Binding BrowserVM.TotalAssets, StringFormat='{}{0} assets'}"/>
                    </WrapPanel>
                </GroupBox>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            Margin="0,0,6,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BrowserVM.FilteredAssets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="130" Height="150"
                                                Margin="4"
                                                BorderThickness="1"
                                                BorderBrush="#CCCCCC"
                                                Background="White"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.BrowserVM.SelectAssetCommand,
                                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <Image Source="{Binding Thumbnail}"
                                                       Width="120" Height="120"
                                                       Stretch="Uniform"
                                                       Margin="4"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="9"
                                                           TextTrimming="CharacterEllipsis"
                                                           HorizontalAlignment="Center"
                                                           Margin="2,0,2,2"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            Padding="8">
                        <StackPanel>
                            <TextBlock Text="Aperçu"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <Border BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    Width="180" Height="180"
                                    Margin="0,0,0,8">
                                <Image Source="{Binding BrowserVM.PreviewImage}"
                                       Stretch="Uniform"/>
                            </Border>

                            <TextBlock Text="{Binding BrowserVM.SelectedAsset.Name}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4"/>

                            <TextBlock FontSize="10" Margin="0,0,0,2">
                                <Run Text="Catégorie : " Foreground="Gray"/>
                                <Run Text="{Binding BrowserVM.SelectedAsset.Category}"/>
                            </TextBlock>

                            <TextBlock FontSize="10" Margin="0,0,0,2">
                                <Run Text="Dossier : " Foreground="Gray"/>
                                <Run Text="{Binding BrowserVM.SelectedAsset.SubFolder}"/>
                            </TextBlock>

                            <TextBlock FontSize="10" Margin="0,0,0,8">
                                <Run Text="Détail : " Foreground="Gray"/>
                                <Run Text="{Binding BrowserVM.SelectedAsset.SubSubFolder}"/>
                            </TextBlock>

                            <Button Content="Ouvrir le dossier"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding BrowserVM.OpenFolderCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Logs -->
            <GroupBox Grid.Column="2"
                      Grid.Row="0"
                      Grid.RowSpan="2"
                      Margin="4,0,0,0"
                      Header="Logs">
                <ListBox ItemsSource="{Binding ScanVM.LogMessages}"
                         FontFamily="Consolas"
                         FontSize="10"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </GroupBox>

        </Grid>
    </Grid>
</Window>