<Window x:Class="SL_Asset_Extractor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arise"
        Width="900" Height="550"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="MS Sans Serif"
        FontSize="12">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="MinWidth" Value="75"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <!-- Colonne gauche -->
        <ScrollViewer Grid.Column="0"
                      Grid.Row="0"
                      Grid.RowSpan="2"
                      Margin="0,0,6,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <GroupBox Header="Dossiers sources">
                    <StackPanel>
                        <ListBox ItemsSource="{Binding SourceFolders}"
                                 MaxHeight="150"
                                 Margin="0,0,0,4"
                                 FontSize="10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1"
                                                Content="X"
                                                Width="18"
                                                Height="18"
                                                FontSize="9"
                                                Margin="4,0,0,0"
                                                Command="{Binding DataContext.RemoveSourceFolderCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="+ Ajouter un dossier"
                                HorizontalAlignment="Stretch"
                                Command="{Binding AddSourceFolderCommand}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Dossier d'export">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ExportFolder}"
                                 IsReadOnly="True"
                                 Padding="2,1"/>
                        <Button Grid.Column="1"
                                Content="..."
                                Width="24"
                                Margin="2,0,0,0"
                                Command="{Binding BrowseExportFolderCommand}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Options">
                    <StackPanel>
                        <CheckBox Content="Texture2D"
                                  IsChecked="{Binding ExtractTexture2D}"
                                  Margin="0,0,0,4"/>
                        <CheckBox Content="Sprite"
                                  IsChecked="{Binding ExtractSprite}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Actions">
                    <StackPanel>
                        <Button Content="Démarrer"
                                Command="{Binding StartExtractionCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,4"/>
                        <Button Content="Annuler"
                                Command="{Binding CancelCommand}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Statut">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>
                        <ProgressBar Value="{Binding Progress}"
                                     Maximum="{Binding ProgressMax}"
                                     Height="14"
                                     Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ProgressText}"
                                   FontSize="10"
                                   Foreground="Gray"/>
                        <TextBlock Text="{Binding TimeRemaining}"
                                   FontSize="10"
                                   Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Zone droite haute -->
        <Border Grid.Column="1"
                Grid.Row="0"
                Margin="0,0,0,6"/>

        <!-- Logs -->
        <GroupBox Grid.Column="1"
                  Grid.Row="1"
                  Header="Logs">
            <ListBox ItemsSource="{Binding LogMessages}"
                     FontFamily="Consolas"
                     FontSize="11"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </GroupBox>

    </Grid>
</Window>